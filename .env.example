# Resend (kontaktskjema)
# Opprett konto på https://resend.com og legg inn verdiene nedenfor.
# Uten RESEND_API_KEY logges henvendelser bare på serveren (skjemaet svarer fortsatt OK).

# API-nøkkel fra Resend → API Keys
RESEND_API_KEY=

# Avsenderadresse — må være verifisert i Resend (domene eller testadresse).
# Eksempel etter domene er verifisert:
# RESEND_FROM_EMAIL=Skyrud Media <kontakt@skyrudmedia.no>
#
# For testing før domene er klart (kun til din egen Resend-konto):
# RESEND_FROM_EMAIL=Skyrud Media <onboarding@resend.dev>
RESEND_FROM_EMAIL=

# Hvor henvendelser skal leveres. Standard: daniel.skyrud@hotmail.com (lib/site.ts)
CONTACT_TO_EMAIL=
